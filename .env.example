# Required - your DeepSeek API key (server-side only, never exposed to frontend)
DEEPSEEK_API_KEY=sk-...

# Tier passphrases (same pattern as your other apps)
FREE_PASSPHRASES=phrase1,phrase2
PRO_PASSPHRASES=phrase3,phrase4
MAX_PASSPHRASES=phrase5,phrase6
ADMIN_PASSPHRASES=adminphrase

# JWT for session tokens
JWT_SECRET=your-secret-here

# Supabase (optional - for future SaaS auth)
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Push reminders
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com
# Shared secret for the reminder dispatch endpoint (used by Supabase Cron)
CRON_SECRET=

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000
